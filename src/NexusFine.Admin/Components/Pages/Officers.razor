@* ── OFFICERS PAGE ── *@
@page "/officers"
@attribute [Authorize(Roles = "Admin,Supervisor")]
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Officers — NexusFine Admin</PageTitle>

<div class="page-header">
    <div class="section-eyebrow">Management</div>
    <h1 class="page-title">Officers</h1>
</div>

<!-- ZONE FILTER -->
<div style="display:flex;gap:10px;margin-bottom:16px;align-items:center">
    @foreach (var zone in new[] { "All", "Lilongwe", "Blantyre", "Mzuzu", "Zomba" })
    {
        <button class="btn btn-sm @(_activeZone==zone?"btn-primary":"btn-ghost")"
                @onclick="() => SetZone(zone)">
            @zone
        </button>
    }
    <button class="btn btn-sm btn-ghost" style="margin-left:auto" @onclick="LoadOfficers">↻ Refresh</button>
    <AuthorizeView Roles="Admin">
        <button class="btn btn-sm btn-gold" @onclick="OpenRegister">＋ Register Officer</button>
    </AuthorizeView>
</div>

@if (_modalOpen)
{
    <div class="modal-shade" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-hdr">
                <div>
                    <div class="section-eyebrow">HQ-only</div>
                    <div class="modal-title">Register Officer</div>
                </div>
                <button class="btn btn-sm btn-ghost" @onclick="CloseModal">✕</button>
            </div>
            @if (!string.IsNullOrEmpty(_modalError))
            {
                <div class="alert alert-danger" style="margin:12px 18px">⚠ @_modalError</div>
            }
            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Badge number *</label>
                        <input class="form-input mono" @bind="_form.BadgeNumber" placeholder="MPS-1042" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Rank *</label>
                        <select class="form-input filter-select" @bind="_form.Rank">
                            <option value="">— Select —</option>
                            <option>Constable</option>
                            <option>Sergeant</option>
                            <option>Sub-Inspector</option>
                            <option>Inspector</option>
                            <option>Superintendent</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">First name *</label>
                        <input class="form-input" @bind="_form.FirstName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last name *</label>
                        <input class="form-input" @bind="_form.LastName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input class="form-input mono" @bind="_form.Phone" placeholder="+265 9..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-input" @bind="_form.Email" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Department *</label>
                        <select class="form-input filter-select" @bind="_form.DepartmentId" @bind:after="ResetStation">
                            <option value="0">— Select —</option>
                            @foreach (var d in _departments)
                            {
                                <option value="@d.Id">@d.Name (@d.Zone)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Station</label>
                        <select class="form-input filter-select" @bind="_form.StationId">
                            <option value="0">— None —</option>
                            @foreach (var s in StationsForDept())
                            {
                                <option value="@s.Id">@s.Name (@s.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">NFC tag ID</label>
                        <input class="form-input mono" @bind="_form.NfcTagId" placeholder="04:A2:..." />
                    </div>
                    <div class="form-group">
                        <label style="display:flex;gap:8px;align-items:center;color:var(--text-on-dark);font-size:13px;margin-top:22px">
                            <input type="checkbox" @bind="_form.IsActive" />
                            Active
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-sm btn-ghost" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-sm btn-gold" @onclick="Save" disabled="@_saving">
                    @(_saving ? "Saving…" : "Register officer")
                </button>
            </div>
        </div>
    </div>
}

<div class="panel">
    <div class="panel-hdr">
        <div>
            <div class="panel-title">Officer Performance — Today</div>
            <div class="panel-sub">@_officers.Count officers · ranked by fines issued</div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-state"><div class="spinner"></div><span>Loading officers...</span></div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" style="margin:16px">⚠ @_error</div>
    }
    else
    {
        <div style="overflow-x:auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Officer</th>
                        <th>Zone</th>
                        <th>Status</th>
                        <th>Device</th>
                        <th>Issued</th>
                        <th>Collected</th>
                        <th>Rate</th>
                        <th>Last Location</th>
                        <th>Last Sync</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_officers.Any())
                    {
                        <tr><td colspan="10" style="text-align:center;color:var(--text-muted-d);padding:32px">No officers found.</td></tr>
                    }
                    @for (int i = 0; i < _officers.Count; i++)
                    {
                        var o = _officers[i];
                        var rate = o.FinesIssued > 0 ? Math.Round((double)o.FinesCollected / o.FinesIssued * 100, 0) : 0;
                        var rateColor = rate >= 75 ? "var(--success-text)" : rate >= 50 ? "var(--warning-text)" : "var(--red-bright)";
                        <tr>
                            <td class="mono" style="color:var(--text-muted-d)">@((i+1).ToString("D2"))</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <img src="@AvatarFor(o)" alt="" style="width:36px;height:36px;border-radius:50%;background:var(--surface-2);border:1px solid var(--border-mid);object-fit:cover;flex-shrink:0" />
                                    <div>
                                        <div style="font-weight:600">@o.FullName</div>
                                        <div class="mono" style="font-size:10px;color:var(--text-muted-d)">#@o.BadgeNumber · @o.Rank</div>
                                    </div>
                                </div>
                            </td>
                            <td style="font-size:12px;color:var(--text-muted-d)">@o.Zone</td>
                            <td><span class="pill pill-@o.Status.ToLower()">@o.Status</span></td>
                            <td class="mono" style="font-size:11px;color:var(--text-muted-d)">@o.DeviceId</td>
                            <td class="mono fw-700" style="color:var(--gold-bright)">@o.FinesIssued</td>
                            <td class="mono fw-700" style="color:var(--success-text)">@o.FinesCollected</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div style="flex:1;height:4px;background:var(--border-mid);border-radius:2px;overflow:hidden">
                                        <div style="width:@rate%;height:100%;background:@rateColor;border-radius:2px"></div>
                                    </div>
                                    <span class="mono" style="font-size:11px;color:var(--text-muted-d)">@rate%</span>
                                </div>
                            </td>
                            <td style="font-size:11px;color:var(--text-muted-d)">📍 @o.LastKnownLocation</td>
                            <td style="font-size:11px;color:var(--text-muted-d)">@o.LastSyncAt?.ToString("HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool   _loading = true;
    private string? _error;
    private List<OfficerPerfDto> _officers = new();
    private string _activeZone = "All";

    // ── registration modal state ──
    private bool _modalOpen, _saving;
    private string? _modalError;
    private OfficerForm _form = new();
    private List<DeptDto>     _departments = new();
    private List<StationRef>  _allStations = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOfficers();
        await LoadRefData();
    }

    private async Task LoadRefData()
    {
        try
        {
            _departments = await Http.GetFromJsonAsync<List<DeptDto>>("api/departments") ?? new();
            _allStations = await Http.GetFromJsonAsync<List<StationRef>>("api/stations?activeOnly=true") ?? new();
        }
        catch { /* registration just won't show ref data */ }
    }

    private async Task SetZone(string zone) { _activeZone = zone; await LoadOfficers(); }

    private void OpenRegister()
    {
        _form = new OfficerForm { IsActive = true };
        _modalError = null;
        _modalOpen = true;
    }

    private void CloseModal() { _modalOpen = false; _saving = false; }

    private void ResetStation() { _form.StationId = 0; }

    private IEnumerable<StationRef> StationsForDept() =>
        _form.DepartmentId == 0 ? _allStations : _allStations.Where(s => s.DepartmentId == _form.DepartmentId);

    private async Task Save()
    {
        _modalError = null;
        if (string.IsNullOrWhiteSpace(_form.BadgeNumber) ||
            string.IsNullOrWhiteSpace(_form.FirstName)   ||
            string.IsNullOrWhiteSpace(_form.LastName)    ||
            string.IsNullOrWhiteSpace(_form.Rank)        ||
            _form.DepartmentId == 0)
        {
            _modalError = "Badge, name, rank and department are required.";
            return;
        }

        _saving = true;
        try
        {
            var payload = new
            {
                badgeNumber         = _form.BadgeNumber.Trim(),
                firstName           = _form.FirstName.Trim(),
                lastName            = _form.LastName.Trim(),
                rank                = _form.Rank.Trim(),
                phone               = _form.Phone?.Trim(),
                email               = _form.Email?.Trim(),
                nfcTagId            = _form.NfcTagId?.Trim(),
                departmentId        = _form.DepartmentId,
                stationId           = _form.StationId == 0 ? (int?)null : _form.StationId,
                primaryPatrolPostId = (int?)null,
                isActive            = _form.IsActive
            };

            var resp = await Http.PostAsJsonAsync("api/officers", payload);
            if (!resp.IsSuccessStatusCode)
            {
                var problem = await resp.Content.ReadFromJsonAsync<ErrorPayload>();
                _modalError = problem?.message ?? $"Save failed ({(int)resp.StatusCode}).";
                return;
            }

            _modalOpen = false;
            await LoadOfficers();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    record DeptDto(int Id, string Name, string Zone);
    record StationRef(int Id, string Code, string Name, int DepartmentId, string Zone);
    record ErrorPayload(string? message);

    class OfficerForm
    {
        public string  BadgeNumber  { get; set; } = "";
        public string  FirstName    { get; set; } = "";
        public string  LastName     { get; set; } = "";
        public string  Rank         { get; set; } = "";
        public string? Phone        { get; set; }
        public string? Email        { get; set; }
        public string? NfcTagId     { get; set; }
        public int     DepartmentId { get; set; }
        public int     StationId    { get; set; }
        public bool    IsActive     { get; set; } = true;
    }

    private async Task LoadOfficers()
    {
        _loading = true; _error = null;
        try
        {
            var url = "api/officers/performance";
            if (_activeZone != "All") url += $"?zone={_activeZone}";
            _officers = await Http.GetFromJsonAsync<List<OfficerPerfDto>>(url) ?? new();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    // Pool restricted to the proper portrait SVGs the user uploaded.
    // The legacy avatar-male-1..3 / avatar-female-1..2 SVGs are tiny placeholders
    // that render as a landscape/crest icon, so they're excluded.
    private static readonly string[] _avatars = new[]
    {
        "img/officers/avatar-male-4.svg",
        "img/officers/avatar-male-5.svg",
        "img/officers/avatar-female-3.svg",
        "img/officers/avatar-female-4.svg"
    };

    private static string AvatarFor(OfficerPerfDto o)
    {
        if (string.IsNullOrEmpty(o.BadgeNumber)) return "img/officers/avatar-default.svg";
        var hash = 0;
        foreach (var c in o.BadgeNumber) hash = unchecked(hash * 31 + c);
        var idx = Math.Abs(hash) % _avatars.Length;
        return _avatars[idx];
    }

    record OfficerPerfDto(
        string   BadgeNumber,
        string   FullName,
        string   Rank,
        string   Status,
        string   Zone,
        string?  DeviceId,
        string?  LastKnownLocation,
        DateTime? LastSyncAt,
        int      FinesIssued,
        int      FinesCollected,
        decimal  AmountIssued,
        decimal  AmountCollected,
        double   CollectionRate
    );
}

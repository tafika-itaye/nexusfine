@*
    Reusable "this surface is planned for pilot phase" panel.
    Used by every sidebar nav item that hasn't shipped yet.
    Keeps the demo from showing dead 404s while signalling
    the planned scope to the Minister / reviewer.
*@

<div class="page-header">
    <div class="section-eyebrow">@Eyebrow</div>
    <h1 class="page-title">@Title</h1>
</div>

<div class="panel" style="padding:48px 32px;text-align:center">
    <div style="font-size:48px;line-height:1;margin-bottom:16px">@Icon</div>
    <div style="font-size:18px;font-weight:700;color:var(--text-on-dark);margin-bottom:6px">
        @Title — Pilot phase
    </div>
    <div style="font-size:13px;color:var(--text-muted-d);max-width:560px;margin:0 auto 22px;line-height:1.6">
        @Description
    </div>

    @if (Bullets is not null && Bullets.Length > 0)
    {
        <div style="display:inline-block;text-align:left;background:var(--surface-2);border:1px solid var(--border-mid);border-radius:var(--radius);padding:18px 24px;max-width:520px;width:100%">
            <div class="section-eyebrow" style="margin-bottom:10px">In scope</div>
            <ul style="margin:0;padding-left:20px;color:var(--text-on-dark);font-size:13px;line-height:1.8">
                @foreach (var b in Bullets)
                {
                    <li>@b</li>
                }
            </ul>
        </div>
    }

    <div style="margin-top:26px">
        <span class="pill pill-disputed">Pilot · 90 days</span>
    </div>
</div>

@code {
    [Parameter] public string  Eyebrow     { get; set; } = "Roadmap";
    [Parameter] public string  Title       { get; set; } = "Coming Soon";
    [Parameter] public string  Icon        { get; set; } = "🛠";
    [Parameter] public string  Description { get; set; } = "This surface is in design and ships during the pilot phase.";
    [Parameter] public string[]? Bullets    { get; set; }
}

@*
    Two-column read-only field row used by the Settings page.
    Renders a small uppercase label and the value; if Mono is true,
    the value uses the monospace font.
*@

<div style="display:flex;justify-content:space-between;gap:14px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:13px">
    <div style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted-d);flex-shrink:0">
        @Label
    </div>
    <div class="@(Mono ? "mono" : "")" style="color:var(--text-on-dark);text-align:right;word-break:break-all">
        @Value
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public bool Mono { get; set; } = false;
}

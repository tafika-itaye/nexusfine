@using Microsoft.AspNetCore.Components.Routing

<nav class="sidebar">
    <div class="sidebar-brand">
        <div class="gov-strip">
            <div class="flag-mini">
                <span class="f1"></span>
                <span class="f2"></span>
                <span class="f3"></span>
            </div>
            MPS · DRTSS
        </div>
        <div class="brand-row">
            <div class="brand-eagle"><img src="img/gov/mps-crest.png" alt="MPS" /></div>
            <div>
                <div class="brand-name">NEXUS<span>FINE</span></div>
                <div class="brand-sub">Admin Portal</div>
            </div>
        </div>
    </div>

    <div class="nav-group-label">Operations</div>
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        <span class="ni">📊</span> Dashboard
    </NavLink>
    <NavLink class="nav-item" href="fines">
        <span class="ni">📋</span> All Fines
    </NavLink>
    <NavLink class="nav-item" href="payments">
        <span class="ni">💳</span> Payments
    </NavLink>
    <NavLink class="nav-item" href="reconciliation">
        <span class="ni">🔁</span> Reconciliation
    </NavLink>

    <div class="nav-group-label">Management</div>
    <NavLink class="nav-item" href="officers">
        <span class="ni">👮</span> Officers
    </NavLink>
    <NavLink class="nav-item" href="departments">
        <span class="ni">🏢</span> Departments
    </NavLink>
    <NavLink class="nav-item" href="offencecodes">
        <span class="ni">⚖️</span> Offence Codes
    </NavLink>

    <div class="nav-group-label">Reports</div>
    <NavLink class="nav-item" href="analytics">
        <span class="ni">📈</span> Analytics
    </NavLink>
    <NavLink class="nav-item" href="auditlog">
        <span class="ni">📄</span> Audit Log
    </NavLink>

    <div class="nav-group-label">System</div>
    <NavLink class="nav-item" href="alerts">
        <span class="ni">🔔</span> Alerts
    </NavLink>
    <NavLink class="nav-item" href="settings">
        <span class="ni">⚙️</span> Settings
    </NavLink>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="user-row">
                    <div class="user-av">@Initials(GetFullName(context))</div>
                    <div style="flex:1;min-width:0">
                        <div class="user-name" title="@GetFullName(context)">@GetFullName(context)</div>
                        <div class="user-role">@GetTopRole(context)</div>
                    </div>
                </div>
                <a href="logout" class="btn btn-sm btn-ghost btn-block" style="margin-top:10px">⎋ Sign out</a>
            </Authorized>
            <NotAuthorized>
                <a href="login" class="btn btn-sm btn-primary btn-block">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private static string GetFullName(Microsoft.AspNetCore.Components.Authorization.AuthenticationState ctx)
    {
        var u = ctx.User;
        return u.FindFirst("fullName")?.Value
            ?? u.Identity?.Name
            ?? "User";
    }

    private static string GetTopRole(Microsoft.AspNetCore.Components.Authorization.AuthenticationState ctx)
    {
        var role = ctx.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        return string.IsNullOrEmpty(role) ? "Member" : role;
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0]).ToUpperInvariant();
    }
}

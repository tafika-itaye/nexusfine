@inherits LayoutComponentBase

<div class="admin-layout">
    <NavMenu />
    <div class="main">
        <div class="topbar">
            <div>
                <div class="topbar-title">@Title</div>
                <div class="topbar-crumb">NexusFine · Malawi Police Service · Traffic Department</div>
            </div>
            <div class="topbar-right">
                <div class="date-chip">@DateTime.Now.ToString("ddd dd MMM yyyy · HH:mm")</div>
                <button class="notif-btn">🔔</button>
            </div>
        </div>
        <div class="content">
            @Body
        </div>
    </div>
</div>

<div id="blazor-error-ui" style="display:none">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [CascadingParameter] public string Title { get; set; } = "Dashboard";
}

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NexusFine.Mobile.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0e1729"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- MPS LOGO AREA -->
            <Frame BackgroundColor="#1a2744" BorderColor="#c8960c"
                   CornerRadius="40" HeightRequest="80" WidthRequest="80"
                   HorizontalOptions="Center" Padding="0" HasShadow="False">
                <Label Text="🦅" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>

            <Label Text="NEXUSFINE" FontSize="24" FontAttributes="Bold"
                   TextColor="#f0b429" HorizontalOptions="Center"
                   Margin="0,16,0,4" CharacterSpacing="4"/>
            <Label Text="MPS OFFICER PORTAL" FontSize="11" TextColor="#7b8db8"
                   HorizontalOptions="Center" CharacterSpacing="3" Margin="0,0,0,8"/>

            <!-- GOV STRIP -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,40">
                <BoxView Color="#000000" HeightRequest="10" WidthRequest="4" VerticalOptions="Center"/>
                <BoxView Color="#ce1126" HeightRequest="10" WidthRequest="4" VerticalOptions="Center"/>
                <BoxView Color="#339e35" HeightRequest="10" WidthRequest="4" VerticalOptions="Center"/>
                <Label Text="Republic of Malawi · Malawi Police Service"
                       FontSize="10" TextColor="#7b8db8" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- ERROR MESSAGE -->
            <Frame x:Name="ErrorFrame" BackgroundColor="#c0392b22" BorderColor="#c0392b"
                   CornerRadius="8" Padding="12,10" IsVisible="False" Margin="0,0,0,16">
                <Label x:Name="ErrorLabel" TextColor="#e74c3c" FontSize="13"/>
            </Frame>

            <!-- BADGE NUMBER -->
            <Label Text="BADGE NUMBER" FontSize="10" TextColor="#7b8db8"
                   CharacterSpacing="2" Margin="0,0,0,6"/>
            <Frame BackgroundColor="#0e1729" BorderColor="#2a3d6b"
                   CornerRadius="8" Padding="0" HasShadow="False" Margin="0,0,0,16">
                <Entry x:Name="BadgeEntry"
                       Placeholder="e.g. T-0024"
                       PlaceholderColor="#2a3d6b"
                       TextColor="#e8edf8"
                       BackgroundColor="Transparent"
                       FontFamily="OpenSansRegular"
                       FontSize="15"
                       Margin="14,10"
                       Keyboard="Text"
                       ReturnType="Next"/>
            </Frame>

            <!-- OFFICER NAME (demo auth — real system uses JWT) -->
            <Label Text="FULL NAME" FontSize="10" TextColor="#7b8db8"
                   CharacterSpacing="2" Margin="0,0,0,6"/>
            <Frame BackgroundColor="#0e1729" BorderColor="#2a3d6b"
                   CornerRadius="8" Padding="0" HasShadow="False" Margin="0,0,0,32">
                <Entry x:Name="NameEntry"
                       Placeholder="e.g. Constable L. Phiri"
                       PlaceholderColor="#2a3d6b"
                       TextColor="#e8edf8"
                       BackgroundColor="Transparent"
                       FontFamily="OpenSansRegular"
                       FontSize="15"
                       Margin="14,10"
                       ReturnType="Done"/>
            </Frame>

            <!-- LOGIN BUTTON -->
            <Button x:Name="LoginButton"
                    Text="Sign In →"
                    BackgroundColor="#c0392b"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="8"
                    HeightRequest="52"
                    Clicked="OnLoginClicked"/>

            <Label Text="NexusFine v1.0 · TechNexus MW · technexusmw.com"
                   FontSize="10" TextColor="#3a4a6b"
                   HorizontalOptions="Center" Margin="0,32,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
